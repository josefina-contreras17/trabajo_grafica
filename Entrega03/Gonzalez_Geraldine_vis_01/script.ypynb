      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "fig = px.line_polar(\n",
        "    r=list(promedios.values()),\n",
        "    theta=list(promedios.keys()),\n",
        "    line_close=True\n",
        ")\n",
        "\n",
        "fig.update_traces(fill='toself')\n",
        "\n",
        "fig.update_layout(\n",
        "    title='Perfil promedio del rock chileno',\n",
        "    polar=dict(\n",
        "        radialaxis=dict(\n",
        "            visible=True,\n",
        "            range=[0,1]\n",
        "        )\n",
        "    )\n",
        ")\n",
        "\n",
        "fig.show()"
      ],
