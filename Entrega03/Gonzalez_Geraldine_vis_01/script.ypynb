    {
      "cell_type": "code",
      "source": [
        "chart = alt.Chart(promedios_df).mark_bar().encode(\n",
        "    x='Promedio:Q',\n",
        "    y=alt.Y('Atributo:N', sort='-x')\n",
        ").properties(\n",
        "    width=600,\n",
        "    height=300,\n",
        "    title='Perfil promedio del rock chileno'\n",
        ")\n",
        "\n",
        "chart"
      ],
