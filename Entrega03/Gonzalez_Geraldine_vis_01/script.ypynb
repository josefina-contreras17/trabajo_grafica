    {
      "cell_type": "code",
      "source": [
        "promedios = {\n",
        "    'Danceability': df['Danceability'].mean(),\n",
        "    'Energy': df['Energy'].mean(),\n",
        "    'Acousticness': df['Acousticness'].mean(),\n",
        "    'Instrumentalness': df['Instrumentalness'].mean(),\n",
        "    'Liveness': df['Liveness'].mean(),\n",
        "    'Speechiness': df['Speechiness'].mean(),\n",
        "    'Valence': df['Valence'].mean()\n",
        "}"
      ],
      "metadata": {
        "id": "zL_FOId0pB2r"
      },
      "execution_count": 22,
      "outputs": []
